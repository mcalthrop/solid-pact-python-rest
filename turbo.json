{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "openapi:generate": {
      "cache": false
    },
    "openapi:validate": {
      "cache": false
    },
    "test": {},
    "test:coverage": {},
    "knip": {}
  }
}
